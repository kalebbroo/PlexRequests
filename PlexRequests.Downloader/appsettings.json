{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "System.Net.Http.HttpClient": "Warning"
    }
  },
  "Api": {
    "BaseUrl": "http://localhost:5000",
    "Key": ""
  },
  "Worker": {
    "PollIntervalSeconds": 15,
    "MaxConcurrent": 2,
    "ClaimBatchSize": 5,
    "WorkerId": "downloader"
  },
  "Indexer": {
    "TimeoutSeconds": 20,
    "EztvBaseUrl": "https://eztvx.to",
    "YtsBaseUrl": "https://yts.mx",
    "X1337xBaseUrl": "https://1337x.to",
    "X1337xEnabled": true,
    "X1337xMaxDetail": 8,
    "NyaaBaseUrl": "https://nyaa.si",
    "NyaaEnabled": true,
    "NyaaCategory": "1_2",
    "ExtToBaseUrl": "https://ext.to",
    "ExtToEnabled": true,
    "ExtToSearchPath": "/search/?q={query}&order=seeders&sort=desc",
    "ExtToMaxDetail": 8
  },
  "Deluge": {
    "Url": "",
    "Password": "",
    "MovieLabel": "movies",
    "TvLabel": "tv"
  },
  "Library": {
    "MoviePath": "",
    "TvPath": "",
    "Hardlink": true
  },
  "Quality": {
    "MinSeeders": 1,
    "MaxSizeGb": 25,
    "PreferredGroups": []
  },
  "Vpn": {
    "Enabled": true,
    "HealthCheckUrl": "https://api.ipify.org",
    "TimeoutSeconds": 10
  }
}
