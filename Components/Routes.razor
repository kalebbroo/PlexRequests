@using MudBlazor
@using Microsoft.AspNetCore.Components.Authorization
@using PlexRequestsHosted.Components.Shared

@* Single interactive boundary for the whole app. Rendered from App.razor with
   @@rendermode InteractiveServer so the layout (header, notifications, search, sign-out) and every
   page are interactive — not just the page body. Mud providers live here so their popovers/dialogs
   share this interactive root. *@
<CascadingAuthenticationState>
    <MudThemeProvider Theme="@_theme" IsDarkMode="true" />
    <MudPopoverProvider />
    <MudDialogProvider />
    <MudSnackbarProvider />
    <Router AppAssembly="typeof(App).Assembly">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="@routeData" DefaultLayout="typeof(PlexRequestsHosted.Components.Layout.MainLayout)">
                <Authorizing>
                    <LayoutView Layout="typeof(PlexRequestsHosted.Components.Layout.MainLayout)">
                        <div class="m-4"><p>Signing you in...</p></div>
                    </LayoutView>
                </Authorizing>
                <NotAuthorized>
                    <RedirectToLogin />
                </NotAuthorized>
            </AuthorizeRouteView>
        </Found>
        <NotFound>
            <LayoutView Layout="typeof(PlexRequestsHosted.Components.Layout.MainLayout)">
                <MudText Typo="Typo.h5" Class="m-4">Sorry, there's nothing at this address.</MudText>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>

@code {
    private readonly MudTheme _theme = new()
    {
        PaletteDark = new PaletteDark()
        {
            Primary = "#E5A00D",
            PrimaryContrastText = "#000000",
            Secondary = "#CC8A0B",
            Background = "#141414",
            Surface = "#181818",
            AppbarBackground = "rgba(20, 20, 20, 0)",
            AppbarText = "#FFFFFF",
            TextPrimary = "#FFFFFF",
            TextSecondary = "#B3B3B3",
            ActionDefault = "#B3B3B3",
            ActionDisabled = "#4B4B4B",
            Divider = "rgba(255,255,255,0.1)",
            DividerLight = "#2A2A2A",
            Success = "#46d369",
            Warning = "#ffa500",
            Error = "#f44336",
            Info = "#2196f3"
        },
        Typography = new Typography()
        {
            Default = new DefaultTypography()
            {
                FontFamily = new[] { "-apple-system", "BlinkMacSystemFont", "Segoe UI", "Roboto", "Helvetica Neue", "Arial", "sans-serif" }
            }
        }
    };
}
