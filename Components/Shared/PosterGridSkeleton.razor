@* Placeholder poster grid shown while real cards load — keeps the layout stable and feels instant. *@
<div class="skeleton-grid">
    @for (int i = 0; i < Count; i++)
    {
        <div class="skeleton-poster">
            <MudSkeleton SkeletonType="SkeletonType.Rectangle" Animation="Animation.Wave"
                         Width="100%" Height="100%" Class="skeleton-fill" />
        </div>
    }
</div>

@code {
    [Parameter] public int Count { get; set; } = 12;
}
