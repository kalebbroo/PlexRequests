@using PlexRequestsHosted.Shared.DTOs
@using PlexRequestsHosted.Shared.Enums
@inject NavigationManager Navigation

@* Unified poster card. CSS-only hover (no JS timer -> no leak), overlay stays INSIDE the card so a
   grid or row never shifts. Click -> details; quick actions stop propagation. *@
<div class="mcard" @onclick="NavigateToDetails" title="@Media.Title">
    <div class="mcard-poster">
        @if (!string.IsNullOrEmpty(Media.PosterUrl))
        {
            <img src="@Media.PosterUrl" alt="@Media.Title" loading="lazy"
                 onerror="this.onerror=null;this.src='/img/poster-placeholder.svg'" />
        }
        else
        {
            <div class="mcard-placeholder"><MudIcon Icon="@GetMediaIcon()" Size="Size.Large" /></div>
        }

        @if (Media.IsAvailable)
        {
            <div class="mcard-badge available" title="Available on Plex"><MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" /></div>
        }
        else if (Media.RequestStatus == RequestStatus.Pending)
        {
            <div class="mcard-badge pending" title="Requested"><MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" /></div>
        }
        else if (Media.RequestStatus == RequestStatus.Approved || Media.RequestStatus == RequestStatus.Processing)
        {
            <div class="mcard-badge approved" title="Approved / downloading"><MudIcon Icon="@Icons.Material.Filled.Downloading" Size="Size.Small" /></div>
        }

        @if (Media.MediaType == MediaType.TvShow && Media.TotalSeasons > 0)
        {
            <div class="mcard-seasons">@Media.TotalSeasons @(Media.TotalSeasons == 1 ? "Season" : "Seasons")</div>
        }

        <div class="mcard-overlay">
            <div class="mcard-overlay-top">
                @if (Media.Rating.HasValue && Media.Rating.Value > 0)
                {
                    <span class="mcard-rating"><MudIcon Icon="@Icons.Material.Filled.Star" Size="Size.Small" /> @Media.Rating.Value.ToString("0.0")</span>
                }
            </div>
            <div class="mcard-overlay-body">
                <div class="mcard-title">@Media.Title</div>
                <div class="mcard-meta">
                    @if (Media.Year.HasValue) { <span>@Media.Year</span> }
                    <span class="mcard-type">@(Media.MediaType == MediaType.TvShow ? "TV" : "Movie")</span>
                </div>
                <div class="mcard-actions">
                    @if (Media.IsAvailable)
                    {
                        <button class="mcard-btn primary" @onclick:stopPropagation="true" @onclick="HandlePlay">
                            <MudIcon Icon="@Icons.Material.Filled.PlayArrow" Size="Size.Small" /> Play
                        </button>
                    }
                    else if (Media.RequestStatus == RequestStatus.None)
                    {
                        <button class="mcard-btn primary" @onclick:stopPropagation="true" @onclick="HandleRequest">
                            <MudIcon Icon="@Icons.Material.Filled.Add" Size="Size.Small" /> Request
                        </button>
                    }
                    else
                    {
                        <button class="mcard-btn muted" disabled>@GetStatusText()</button>
                    }
                    <button class="mcard-btn icon" title="Details" @onclick:stopPropagation="true" @onclick="NavigateToDetails">
                        <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" />
                    </button>
                    @if (OnRemove.HasDelegate)
                    {
                        <button class="mcard-btn icon danger" title="Remove" @onclick:stopPropagation="true" @onclick="HandleRemove">
                            <MudIcon Icon="@Icons.Material.Filled.Close" Size="Size.Small" />
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public MediaCardDto Media { get; set; } = default!;
    [Parameter] public EventCallback<MediaCardDto> OnRequest { get; set; }
    [Parameter] public EventCallback<MediaCardDto> OnPlay { get; set; }
    [Parameter] public EventCallback<MediaCardDto> OnRemove { get; set; }

    private async Task HandleRequest() { if (OnRequest.HasDelegate) await OnRequest.InvokeAsync(Media); }
    private async Task HandlePlay() { if (OnPlay.HasDelegate) await OnPlay.InvokeAsync(Media); }
    private async Task HandleRemove() { if (OnRemove.HasDelegate) await OnRemove.InvokeAsync(Media); }

    private void NavigateToDetails()
        => Navigation.NavigateTo($"/media/{Media.MediaType.ToString().ToLower()}/{Media.Id}");

    private string GetMediaIcon() => Media.MediaType switch
    {
        MediaType.Movie => Icons.Material.Filled.Movie,
        MediaType.TvShow => Icons.Material.Filled.Tv,
        _ => Icons.Material.Filled.VideoLibrary
    };

    private string GetStatusText() => Media.RequestStatus switch
    {
        RequestStatus.Pending => "Pending",
        RequestStatus.Approved => "Approved",
        RequestStatus.Processing => "Downloading",
        RequestStatus.Available => "Available",
        RequestStatus.PartiallyAvailable => "Partially available",
        RequestStatus.Rejected => "Denied",
        _ => "Requested"
    };
}
