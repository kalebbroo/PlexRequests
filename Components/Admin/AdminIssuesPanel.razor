@using PlexRequestsHosted.Shared.DTOs
@using PlexRequestsHosted.Shared.Enums
@inject PlexRequestsHosted.Services.Implementations.IMediaIssueService IssueService
@inject PlexRequestsHosted.Services.Abstractions.IToastService Toast

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Reported Problems</h2>
    <div class="d-flex gap-2 align-items-center">
        <MudSwitch T="bool" Value="_openOnly" Label="Open only" Color="Color.Primary" ValueChanged="OnOpenOnlyChanged" />
        <MudButton Color="Color.Primary" Variant="Variant.Outlined" OnClick="Load">Refresh</MudButton>
    </div>
</div>

@if (_loading)
{
    <div class="d-flex justify-content-center py-6"><MudProgressCircular Indeterminate="true" Color="Color.Primary" /></div>
}
else if (_issues.Count == 0)
{
    <div class="text-center py-6 text-muted">No reported problems @(_openOnly ? "open" : "").</div>
}
else
{
    <MudTable Items="_issues" Dense="true" Hover="true" Class="elevation-1">
        <HeaderContent>
            <MudTh>Title</MudTh>
            <MudTh>Problem</MudTh>
            <MudTh>Details</MudTh>
            <MudTh>Reported by</MudTh>
            <MudTh>When</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>
                <div class="d-flex align-items-center gap-2">
                    @if (!string.IsNullOrWhiteSpace(context.PosterUrl))
                    {
                        <img src="@context.PosterUrl" alt="" loading="lazy" style="width:36px;height:54px;object-fit:cover;border-radius:4px;" />
                    }
                    <div>
                        <div class="fw-bold">@context.Title</div>
                        <div class="text-muted small">@(context.MediaType == MediaType.Movie ? "Movie" : context.MediaType == MediaType.TvShow ? "TV" : context.MediaType.ToString())
                            @if (context.SeasonNumber is int s) { <text> · S@(s)@(context.EpisodeNumber is int e ? $"E{e}" : "")</text> }</div>
                    </div>
                </div>
            </MudTd>
            <MudTd>@context.Reason</MudTd>
            <MudTd Style="max-width:280px;white-space:normal;">@context.Detail</MudTd>
            <MudTd>@context.ReportedBy</MudTd>
            <MudTd>@context.CreatedAt.ToLocalTime().ToString("g")</MudTd>
            <MudTd>
                <MudChip T="string" Size="Size.Small"
                         Color="@(context.Status == IssueStatus.Open ? Color.Warning : context.Status == IssueStatus.Resolved ? Color.Success : Color.Default)">
                    @context.Status
                </MudChip>
            </MudTd>
            <MudTd>
                @if (context.Status == IssueStatus.Open)
                {
                    <div class="d-flex gap-1">
                        <MudButton Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled" OnClick="() => Redownload(context)">Re-download</MudButton>
                        <MudButton Size="Size.Small" Color="Color.Success" Variant="Variant.Text" OnClick="() => Resolve(context)">Resolve</MudButton>
                        <MudButton Size="Size.Small" Color="Color.Default" Variant="Variant.Text" OnClick="() => Dismiss(context)">Dismiss</MudButton>
                    </div>
                }
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private bool _loading = true;
    private bool _openOnly = true;
    private List<MediaIssueDto> _issues = new();

    protected override async Task OnInitializedAsync()
    {
        await Load();
    }

    private async Task Load()
    {
        _loading = true;
        StateHasChanged();
        try { _issues = await IssueService.GetIssuesAsync(_openOnly); }
        finally { _loading = false; StateHasChanged(); }
    }

    private async Task OnOpenOnlyChanged(bool v) { _openOnly = v; await Load(); }

    private async Task Redownload(MediaIssueDto i)
    {
        if (await IssueService.RequestRedownloadAsync(i.Id))
        {
            await Toast.ShowSuccessAsync($"Re-download queued for {i.Title}.");
            await Load();
        }
        else await Toast.ShowErrorAsync("Failed to queue re-download.");
    }

    private async Task Resolve(MediaIssueDto i)
    {
        if (await IssueService.ResolveIssueAsync(i.Id)) { await Toast.ShowInfoAsync("Marked resolved."); await Load(); }
    }

    private async Task Dismiss(MediaIssueDto i)
    {
        if (await IssueService.DismissIssueAsync(i.Id)) { await Toast.ShowInfoAsync("Dismissed."); await Load(); }
    }
}
