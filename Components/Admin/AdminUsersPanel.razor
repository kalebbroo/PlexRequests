@using PlexRequestsHosted.Services.Abstractions
@inject IUserProfileService UserProfiles
@inject IToastService Toast

<h2 class="mb-3">Users &amp; Roles</h2>

@if (_loading)
{
    <MudProgressCircular Indeterminate="true" />
}
else if (_users.Count == 0)
{
    <MudText>No users have signed in yet.</MudText>
}
else
{
    <MudTable Items="_users" Dense="true">
        <HeaderContent>
            <MudTh>User</MudTh>
            <MudTh>Plex Username</MudTh>
            <MudTh>Roles</MudTh>
            <MudTh>Admin</MudTh>
            <MudTh>Auto-approve</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="User">@(string.IsNullOrWhiteSpace(context.DisplayName) ? context.Username : context.DisplayName)</MudTd>
            <MudTd DataLabel="Plex Username">@context.PlexUsername</MudTd>
            <MudTd DataLabel="Roles">@string.Join(", ", context.Roles)</MudTd>
            <MudTd DataLabel="Admin">
                <MudSwitch T="bool" Value="@context.Roles.Contains("Admin")" Color="Color.Primary"
                           ValueChanged="@(v => ToggleAdmin(context, v))" />
            </MudTd>
            <MudTd DataLabel="Auto-approve">
                <MudTooltip Text="@(context.Roles.Contains("Admin") ? "Admins are always auto-approved" : "Approve this user's requests automatically")">
                    <MudSwitch T="bool" Value="@(context.AutoApprove || context.Roles.Contains("Admin"))" Color="Color.Success"
                               Disabled="@context.Roles.Contains("Admin")"
                               ValueChanged="@(v => ToggleAutoApprove(context, v))" />
                </MudTooltip>
            </MudTd>
        </RowTemplate>
    </MudTable>
    <MudText Typo="Typo.caption" Class="mt-2 d-block text-secondary">
        Role changes take effect the next time that user signs in. Auto-approve applies to new requests immediately. Admins are always auto-approved.
    </MudText>
}

@code {
    private bool _loading = true;
    private List<UserDto> _users = new();

    protected override async Task OnInitializedAsync()
    {
        await Load();
    }

    private async Task Load()
    {
        _loading = true;
        StateHasChanged();
        try
        {
            _users = await UserProfiles.GetAllUsersAsync();
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task ToggleAdmin(UserDto user, bool isAdmin)
    {
        var ok = await UserProfiles.SetAdminAsync(user.Id, isAdmin);
        if (ok)
        {
            await Toast.ShowSuccessAsync($"{(isAdmin ? "Granted" : "Revoked")} admin for {user.Username}");
            await Load();
        }
        else
        {
            await Toast.ShowErrorAsync("Failed to update roles");
        }
    }

    private async Task ToggleAutoApprove(UserDto user, bool autoApprove)
    {
        var ok = await UserProfiles.SetAutoApproveAsync(user.Id, autoApprove);
        if (ok)
        {
            await Toast.ShowSuccessAsync($"{(autoApprove ? "Enabled" : "Disabled")} auto-approve for {user.Username}");
            await Load();
        }
        else
        {
            await Toast.ShowErrorAsync("Failed to update auto-approve");
        }
    }
}
