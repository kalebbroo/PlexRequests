@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject PlexRequestsHosted.Services.Abstractions.INotificationBroker Broker
@inject PlexRequestsHosted.Services.Abstractions.INotificationService Notifications
@implements IDisposable

    
    <div class="app-container">
    @if (!_isLoginPage)
    {
    <header class="app-header @(_isHomepage && !_scrolled ? "transparent" : "") @(_scrolled ? "scrolled" : "")" @onscroll="HandleScroll">
        <div class="header-content">
            <div class="header-left">
                <a href="/browse" class="brand-logo">
                    <MudText Typo="Typo.h5" Class="brand-text">PLEX REQUEST</MudText>
                </a>
                <nav class="main-nav desktop-only">
                    <NavLink href="/browse/movie" class="nav-item">Movies</NavLink>
                    <NavLink href="/browse/tvshow" class="nav-item">TV Shows</NavLink>
                    <NavLink href="/requests" class="nav-item">My Requests</NavLink>
                    <NavLink href="/watchlist" class="nav-item">My List</NavLink>
                    @if (_isAdmin)
                    {
                        <NavLink href="/admin/requests" class="nav-item">Approvals</NavLink>
                        <NavLink href="/admin/issues" class="nav-item">Issues</NavLink>
                        <NavLink href="/admin" class="nav-item">Admin</NavLink>
                        <NavLink href="/admin/quality" class="nav-item">Quality</NavLink>
                    }
                </nav>
            </div>
            
            <div class="header-right">
                <div class="search-container desktop-only @(_searchOpen ? "open" : "")">
                    <MudIconButton Icon="@Icons.Material.Filled.Search" Color="Color.Inherit" OnClick="ToggleSearch" />
                    @if (_searchOpen)
                    {
                        <input type="text" class="search-input" placeholder="Titles, genres, people" @onblur="CloseSearch" @onkeydown="HandleSearchKeyDown" @bind-value="_searchQuery" />
                    }
                </div>
                
                <MudBadge Content="_unreadCount" Color="Color.Error" Overlap="true" Bordered="true"
                          Visible="@(_unreadCount > 0)" Class="desktop-only notification-btn">
                    <MudMenu AnchorOrigin="Origin.BottomLeft" TransformOrigin="Origin.TopLeft">
                        <ActivatorContent>
                            <MudIconButton Icon="@Icons.Material.Filled.Notifications" Color="Color.Inherit" />
                        </ActivatorContent>
                        <ChildContent>
                            @if (_notifications.Any())
                            {
                                @foreach (var notification in _notifications)
                                {
                                    <MudMenuItem>
                                        <div class="notification-item">
                                            <MudText Typo="Typo.body2">@notification.Message</MudText>
                                            <MudText Typo="Typo.caption" Class="text-secondary">@notification.CreatedAt.ToLocalTime().ToString("g")</MudText>
                                        </div>
                                    </MudMenuItem>
                                }
                                <MudDivider />
                                <MudMenuItem OnClick="MarkAllRead">Mark all read</MudMenuItem>
                            }
                            else
                            {
                                <MudMenuItem Disabled="true">No new notifications</MudMenuItem>
                            }
                        </ChildContent>
                    </MudMenu>
                </MudBadge>
                
                <MudMenu AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                    <ActivatorContent>
                        <MudAvatar Size="Size.Small" Class="user-avatar">
                            <MudImage Src="@(_userAvatar ?? "/default-avatar.svg")" />
                        </MudAvatar>
                    </ActivatorContent>
                    <ChildContent>
                        <MudMenuItem Href="/profile">Profile</MudMenuItem>
                        <MudDivider />
                        <MudMenuItem OnClick="SignOut">Sign Out</MudMenuItem>
                    </ChildContent>
                </MudMenu>
                
                <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Class="mobile-only" OnClick="ToggleMobileMenu" />
            </div>
        </div>
    </header>
    }

    @if (_mobileMenuOpen && !_isLoginPage)
    {
        <div class="mobile-menu">
            <nav class="mobile-nav">
                <NavLink href="/browse/movie" class="mobile-nav-item" @onclick="CloseMobileMenu">Movies</NavLink>
                <NavLink href="/browse/tvshow" class="mobile-nav-item" @onclick="CloseMobileMenu">TV Shows</NavLink>
                <NavLink href="/requests" class="mobile-nav-item" @onclick="CloseMobileMenu">My Requests</NavLink>
                <NavLink href="/watchlist" class="mobile-nav-item" @onclick="CloseMobileMenu">My List</NavLink>
                @if (_isAdmin)
                {
                    <NavLink href="/admin/requests" class="mobile-nav-item" @onclick="CloseMobileMenu">Approvals</NavLink>
                    <NavLink href="/admin" class="mobile-nav-item" @onclick="CloseMobileMenu">Admin</NavLink>
                }
                <NavLink href="/search" class="mobile-nav-item" @onclick="CloseMobileMenu">Search</NavLink>
                <MudDivider Class="my-3" />
                <NavLink href="/profile" class="mobile-nav-item" @onclick="CloseMobileMenu">Profile</NavLink>
            </nav>
        </div>
    }

    <main class="main-content">
        <ErrorBoundary>
            <ChildContent>
                @Body
            </ChildContent>
            <ErrorContent>
                <MudContainer MaxWidth="MaxWidth.Large" Class="py-8">
                    <MudAlert Severity="Severity.Error">
                        Something went wrong. Please refresh the page or try again later.
                    </MudAlert>
                </MudContainer>
            </ErrorContent>
        </ErrorBoundary>
    </main>

    @if (!_isLoginPage)
    {
        <footer class="app-footer">
            <MudContainer MaxWidth="MaxWidth.Large">
                <div class="footer-content">
                    <div class="footer-links">
                        <a href="/about">About</a>
                        <a href="/help">Help Center</a>
                        <a href="/terms">Terms of Service</a>
                        <a href="/privacy">Privacy</a>
                    </div>
                    <MudText Typo="Typo.caption" Class="footer-copyright">
                        @DateTime.Now.Year Plex Request. All rights reserved.
                    </MudText>
                </div>
            </MudContainer>
        </footer>
    }
</div>



@code {
    private bool _scrolled = false;
    private bool _searchOpen = false;
    private bool _mobileMenuOpen = false;
    private bool _isHomepage = false;
    private bool _isLoginPage = false;
    private string? _userAvatar;
    private string _searchQuery = string.Empty;
    private int _unreadCount = 0;
    private List<NotificationDto> _notifications = new();
    private int _userId;
    private bool _isAuthenticated = false;
    private bool _isAdmin = false;
    private string? _currentUsername;

    protected override async Task OnInitializedAsync()
    {
        DetermineRouteContext();
        Navigation.LocationChanged += HandleLocationChanged;

        // Get authentication state
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _isAuthenticated = authState.User.Identity?.IsAuthenticated ?? false;
        _currentUsername = authState.User.Identity?.Name;
        _isAdmin = authState.User.IsInRole("Admin");

        if (_isAuthenticated)
        {
            // Get avatar from claims (cheap; no network)
            _userAvatar = authState.User.FindFirst("avatar_url")?.Value;
            int.TryParse(authState.User.FindFirst("user_id")?.Value, out _userId);

            // Subscribe early so live events aren't missed; the actual notification fetch is deferred
            // to OnAfterRender so it never blocks the first paint of the page.
            if (_userId > 0) Broker.Notified += OnNotified;
        }
    }

    private bool _notificationsLoaded = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _userId <= 0 || _notificationsLoaded) return;
        _notificationsLoaded = true;
        // Load persisted notifications after the shell has painted, both queries in parallel.
        var listTask = Notifications.GetForUserAsync(_userId, 20);
        var countTask = Notifications.GetUnreadCountAsync(_userId);
        await Task.WhenAll(listTask, countTask);
        _notifications = listTask.Result;
        _unreadCount = countTask.Result;
        await InvokeAsync(StateHasChanged);
    }

    private async void OnNotified(NotificationDto n)
    {
        if (n.UserId != _userId) return;
        try
        {
            _notifications.Insert(0, n);
            if (_notifications.Count > 20) _notifications = _notifications.Take(20).ToList();
            _unreadCount++;
            await InvokeAsync(StateHasChanged);
        }
        catch { /* component may be disposing */ }
    }

    private async Task MarkAllRead()
    {
        if (_userId <= 0) return;
        await Notifications.MarkAllReadAsync(_userId);
        foreach (var n in _notifications) n.IsRead = true;
        _unreadCount = 0;
        StateHasChanged();
    }

    private void HandleScroll()
    {
        // Header gains a solid background once the page is scrolled past the hero.
        _scrolled = true;
    }

    private void ToggleSearch()
    {
        _searchOpen = !_searchOpen;
    }

    private void CloseSearch()
    {
        _searchOpen = false;
        _searchQuery = string.Empty;
    }

    private void HandleSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_searchQuery))
        {
            Navigation.NavigateTo($"/search?q={Uri.EscapeDataString(_searchQuery)}");
            CloseSearch();
        }
        else if (e.Key == "Escape")
        {
            CloseSearch();
        }
    }

    private void ToggleMobileMenu()
    {
        _mobileMenuOpen = !_mobileMenuOpen;
    }

    private void CloseMobileMenu()
    {
        _mobileMenuOpen = false;
    }

    private async Task SignOut()
    {
        // Cast to CustomAuthStateProvider to access SignOutAsync
        if (AuthStateProvider is PlexRequestsHosted.Services.Auth.CustomAuthStateProvider customProvider)
        {
            await customProvider.SignOutAsync();
        }
        Navigation.NavigateTo("/", true);
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= HandleLocationChanged;
        Broker.Notified -= OnNotified;
    }

    protected override void OnParametersSet()
    {
        DetermineRouteContext();
    }

    private void HandleLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        DetermineRouteContext();
        InvokeAsync(StateHasChanged);
    }

    private void DetermineRouteContext()
    {
        var uri = Navigation.Uri;
        _isHomepage = uri.EndsWith("/browse") || uri.EndsWith("/dashboard");
        _isLoginPage = uri.EndsWith("/login") || uri.EndsWith("/") || uri.Contains("/auth/callback");
    }
}
