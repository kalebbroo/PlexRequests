@page "/Error"
@attribute [AllowAnonymous]
@using System.Diagnostics

<PageTitle>Something went wrong - Plex Requests</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="py-16">
    <div style="text-align: center;">
        <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Color="Color.Error" Style="font-size: 4rem;" />
        <MudText Typo="Typo.h4" Class="mt-4">Something went wrong</MudText>
        <MudText Typo="Typo.body1" Class="text-secondary mt-2">
            An unexpected error occurred while processing your request. Please try again.
        </MudText>

        @if (ShowRequestId)
        {
            <MudText Typo="Typo.caption" Class="text-secondary d-block mt-4">
                Reference ID: <code>@RequestId</code>
            </MudText>
        }

        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/browse" Class="mt-6">
            Back to Browse
        </MudButton>
    </div>
</MudContainer>

@code{
    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    // Activity.Current is populated on the interactive circuit; the old HttpContext cascade was
    // only available during static SSR (disabled here), so it was always null.
    protected override void OnInitialized() => RequestId = Activity.Current?.Id;
}
