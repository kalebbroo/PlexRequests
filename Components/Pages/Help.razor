@page "/help"
@attribute [AllowAnonymous]

<PageTitle>Help - Plex Requests</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="py-8">
    <MudText Typo="Typo.h3" GutterBottom="true">Help Center</MudText>

    <MudText Typo="Typo.h6" Class="mt-4">How do I request something?</MudText>
    <MudText Typo="Typo.body2" Color="Color.Tertiary" Class="mb-3">
        Find a title on the Home, Movies, TV Shows, or Search pages and click <b>Request</b> on the
        poster (or open its details page and request from there). You'll get a notification when it's
        approved and again when it's available on Plex.
    </MudText>

    <MudText Typo="Typo.h6" Class="mt-4">What do the badges mean?</MudText>
    <MudText Typo="Typo.body2" Color="Color.Tertiary" Class="mb-3">
        A green check means the title is already on Plex. A clock means your request is pending, and a
        download icon means it's approved and being fetched.
    </MudText>

    <MudText Typo="Typo.h6" Class="mt-4">My List</MudText>
    <MudText Typo="Typo.body2" Color="Color.Tertiary" Class="mb-3">
        Add titles to <b>My List</b> to keep track of things you want to watch or request later.
    </MudText>

    <MudText Typo="Typo.h6" Class="mt-4">Something not working?</MudText>
    <MudText Typo="Typo.body2" Color="Color.Tertiary">
        Contact your server administrator — they manage requests and the Plex library for this portal.
    </MudText>
</MudContainer>
