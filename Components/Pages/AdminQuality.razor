@page "/admin/quality"
@attribute [Authorize(Roles = "Admin")]
@using PlexRequestsHosted.Shared.DTOs
@using PlexRequestsHosted.Shared.Enums
@inject PlexRequestsHosted.Services.Implementations.IQualityRuleService QualityRules
@inject PlexRequestsHosted.Services.Abstractions.IToastService Toast

<PageTitle>Quality Rules - Plex Requests</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="py-6">
    <div class="d-flex justify-content-between align-items-center mb-2">
        <h2>Download Quality Rules</h2>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="AddRule">Add rule</MudButton>
    </div>
    <MudText Typo="Typo.body2" Color="Color.Tertiary" Class="mb-4">
        Rules are evaluated top to bottom; the first enabled rule whose conditions all match a title sets its
        download quality. Anything unmatched uses the Default. Not shown to users.
    </MudText>

    @if (_loading)
    {
        <div class="d-flex justify-content-center py-6"><MudProgressCircular Indeterminate="true" Color="Color.Primary" /></div>
    }
    else
    {
        @* Default rule *@
        @if (_default is not null)
        {
            <MudPaper Class="pa-4 mb-4" Elevation="1">
                <div class="d-flex align-items-center gap-3 flex-wrap">
                    <MudIcon Icon="@Icons.Material.Filled.Star" Color="Color.Primary" />
                    <b>Default quality</b>
                    <MudText Typo="Typo.body2" Color="Color.Tertiary">applied when no rule below matches</MudText>
                    <MudSpacer />
                    <MudSelect T="Quality" Value="_default.TargetQuality" ValueChanged="v => OnDefaultQuality(v)" Dense="true" Variant="Variant.Outlined" Style="min-width:160px;">
                        @foreach (var q in _qualities) { <MudSelectItem Value="q">@QualityLabel(q)</MudSelectItem> }
                    </MudSelect>
                </div>
            </MudPaper>
        }

        @* Override rules in order *@
        @if (_rules.Count == 0)
        {
            <div class="text-center py-4 text-muted">No override rules yet — add one (e.g. Animation + TV → 720p).</div>
        }
        @for (int i = 0; i < _rules.Count; i++)
        {
            var rule = _rules[i];
            var idx = i;
            <MudPaper Class="pa-4 mb-3" Elevation="1">
                <div class="d-flex align-items-center gap-2 mb-3">
                    <MudChip T="string" Size="Size.Small" Color="Color.Default">#@(idx + 1)</MudChip>
                    <MudTextField @bind-Value="rule.Name" Label="Name" Variant="Variant.Outlined" Dense="true" Style="max-width:240px;" />
                    <MudSpacer />
                    <MudSwitch T="bool" @bind-Value="rule.Enabled" Color="Color.Primary" Label="Enabled" />
                    <MudIconButton Icon="@Icons.Material.Filled.ArrowUpward" Size="Size.Small" Disabled="@(idx == 0)" OnClick="() => Move(rule, true)" />
                    <MudIconButton Icon="@Icons.Material.Filled.ArrowDownward" Size="Size.Small" Disabled="@(idx == _rules.Count - 1)" OnClick="() => Move(rule, false)" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="() => Delete(rule)" />
                </div>
                <div class="d-flex gap-3 flex-wrap align-items-center">
                    <MudSelect T="MediaType?" @bind-Value="rule.MatchMediaType" Label="Media type (any)" Dense="true" Variant="Variant.Outlined" Clearable="true" Style="min-width:150px;">
                        <MudSelectItem T="MediaType?" Value="@((MediaType?)MediaType.Movie)">Movies</MudSelectItem>
                        <MudSelectItem T="MediaType?" Value="@((MediaType?)MediaType.TvShow)">TV Shows</MudSelectItem>
                        <MudSelectItem T="MediaType?" Value="@((MediaType?)MediaType.Music)">Music</MudSelectItem>
                    </MudSelect>
                    <MudTextField @bind-Value="rule.MatchGenre" Label="Genre contains (any)" Placeholder="e.g. Animation" Variant="Variant.Outlined" Dense="true" Style="max-width:200px;" />
                    <MudNumericField T="int?" @bind-Value="rule.MatchTmdbId" Label="Specific TMDB id (any)" Variant="Variant.Outlined" Dense="true" Style="max-width:180px;" HideSpinButtons="true" />
                    <MudIcon Icon="@Icons.Material.Filled.ArrowForward" />
                    <MudSelect T="Quality" @bind-Value="rule.TargetQuality" Label="Quality" Dense="true" Variant="Variant.Outlined" Style="min-width:150px;">
                        @foreach (var q in _qualities) { <MudSelectItem Value="q">@QualityLabel(q)</MudSelectItem> }
                    </MudSelect>
                    <MudButton Color="Color.Primary" Variant="Variant.Outlined" OnClick="() => Save(rule)">Save</MudButton>
                </div>
            </MudPaper>
        }
    }
</MudContainer>

@code {
    private bool _loading = true;
    private QualityRuleDto? _default;
    private List<QualityRuleDto> _rules = new();
    private static readonly Quality[] _qualities = { Quality.SD, Quality.HD, Quality.FullHD, Quality.UHD4K, Quality.UHD8K, Quality.Any };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await Load();
    }

    private async Task Load()
    {
        _loading = true; StateHasChanged();
        try
        {
            var all = await QualityRules.GetRulesAsync();
            _default = all.FirstOrDefault(r => r.IsDefault);
            _rules = all.Where(r => !r.IsDefault).OrderBy(r => r.Order).ToList();
        }
        finally { _loading = false; StateHasChanged(); }
    }

    private async Task OnDefaultQuality(Quality q)
    {
        if (_default is null) return;
        _default.TargetQuality = q;
        await QualityRules.UpdateRuleAsync(_default);
        await Toast.ShowInfoAsync($"Default quality set to {QualityLabel(q)}");
    }

    private async Task AddRule()
    {
        await QualityRules.CreateRuleAsync(new QualityRuleDto { Name = "New rule", TargetQuality = Quality.HD, Enabled = true });
        await Load();
    }

    private async Task Save(QualityRuleDto rule)
    {
        if (await QualityRules.UpdateRuleAsync(rule)) await Toast.ShowSuccessAsync($"Saved '{rule.Name}'.");
        else await Toast.ShowErrorAsync("Save failed.");
    }

    private async Task Move(QualityRuleDto rule, bool up)
    {
        if (await QualityRules.MoveRuleAsync(rule.Id, up)) await Load();
    }

    private async Task Delete(QualityRuleDto rule)
    {
        if (await QualityRules.DeleteRuleAsync(rule.Id)) { await Toast.ShowInfoAsync("Rule deleted."); await Load(); }
    }

    private static string QualityLabel(Quality q) => q switch
    {
        Quality.SD => "480p (SD)",
        Quality.HD => "720p (HD)",
        Quality.FullHD => "1080p (Full HD)",
        Quality.UHD4K => "2160p (4K)",
        Quality.UHD8K => "4320p (8K)",
        _ => "Any"
    };
}
