@page "/about"
@attribute [AllowAnonymous]

<PageTitle>About - Plex Requests</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="py-8">
    <MudText Typo="Typo.h3" GutterBottom="true">About Plex Requests</MudText>
    <MudText Typo="Typo.body1" Class="mb-4">
        Plex Requests is a self-hosted portal that lets the people you share your Plex server with
        browse movies and TV shows and request the titles they'd like added to the library.
        Requests are reviewed by an admin, and — when automatic fulfillment is enabled — approved
        titles are downloaded and added to Plex automatically.
    </MudText>
    <MudText Typo="Typo.body2" Color="Color.Tertiary">
        Metadata and artwork are provided by TMDB. This product uses the TMDB API but is not
        endorsed or certified by TMDB. Plex is a trademark of Plex, Inc.
    </MudText>
</MudContainer>
