@page "/browse/{type}"
@attribute [Authorize]
@using PlexRequestsHosted.Shared.DTOs
@using PlexRequestsHosted.Shared.Enums
@using PlexRequestsHosted.Components.Shared
@inject PlexRequestsHosted.Services.Abstractions.IPlexApiService PlexApiService
@inject PlexRequestsHosted.Services.Abstractions.IMediaRequestService MediaRequestService
@inject PlexRequestsHosted.Services.Abstractions.IToastService ToastService
@inject NavigationManager Navigation

<PageTitle>@GetPageTitle() - Plex Requests</PageTitle>

<div class="browse-page">
    @* Featured hero (default discovery view only) *@
    @if (!GridMode && _featured is not null)
    {
        <section class="browse-hero" style="background-image: url('@(_featured.BackdropUrl ?? _featured.PosterUrl)')">
            <div class="browse-hero-scrim"></div>
            <div class="browse-hero-content">
                <span class="browse-hero-kicker">@(_type == MediaType.TvShow ? "Trending Series" : "Trending Movie")</span>
                <h1 class="browse-hero-title">@_featured.Title</h1>
                <div class="browse-hero-meta">
                    @if (_featured.Rating is > 0) { <span class="bh-rating"><MudIcon Icon="@Icons.Material.Filled.Star" Size="Size.Small" /> @_featured.Rating!.Value.ToString("0.0")</span> }
                    @if (_featured.Year.HasValue) { <span>@_featured.Year</span> }
                    @if (_featured.IsAvailable) { <span class="bh-avail">On Plex</span> }
                </div>
                @if (!string.IsNullOrEmpty(_featured.Overview)) { <p class="browse-hero-overview">@Truncate(_featured.Overview, 200)</p> }
                <div class="browse-hero-actions">
                    @if (_featured.IsAvailable)
                    {
                        <button class="bh-btn primary" @onclick="() => Play(_featured)"><MudIcon Icon="@Icons.Material.Filled.PlayArrow" /> Play</button>
                    }
                    else if (_featured.RequestStatus == RequestStatus.None)
                    {
                        <button class="bh-btn primary" @onclick="() => Request(_featured)"><MudIcon Icon="@Icons.Material.Filled.Add" /> Request</button>
                    }
                    <button class="bh-btn ghost" @onclick="() => Details(_featured)"><MudIcon Icon="@Icons.Material.Filled.Info" /> More Info</button>
                </div>
            </div>
        </section>
    }

    <div class="browse-header @(GridMode || _featured is null ? "solid" : "")">
        <MudContainer MaxWidth="MaxWidth.ExtraLarge">
            <div class="browse-header-row">
                <h1 class="browse-title">@GetPageTitle()</h1>
                <div class="browse-filters">
                    <MudSelect T="MediaType" Value="_type" ValueChanged="OnTypeChanged" Label="Type" Variant="Variant.Outlined" Dense="true" Class="browse-select">
                        <MudSelectItem T="MediaType" Value="MediaType.Movie">Movies</MudSelectItem>
                        <MudSelectItem T="MediaType" Value="MediaType.TvShow">TV Shows</MudSelectItem>
                    </MudSelect>

                    <MudSelect T="string" Value="_genre" ValueChanged="OnGenreChanged" Label="Genre" Variant="Variant.Outlined" Dense="true" Class="browse-select"
                               ToStringFunc="@(g => string.IsNullOrEmpty(g) ? "All Genres" : g)">
                        <MudSelectItem T="string" Value='""'>All Genres</MudSelectItem>
                        @foreach (var g in _genres)
                        {
                            <MudSelectItem T="string" Value="@g">@g</MudSelectItem>
                        }
                    </MudSelect>

                    @if (GridMode)
                    {
                        <MudSelect T="SortOrder" Value="_sort" ValueChanged="OnSortChanged" Label="Sort By" Variant="Variant.Outlined" Dense="true"
                                   ToStringFunc="@(s => SortLabel(s))" Class="browse-select">
                            <MudSelectItem Value="SortOrder.PopularityDescending">Most Popular</MudSelectItem>
                            <MudSelectItem Value="SortOrder.RatingDescending">Highest Rated</MudSelectItem>
                            <MudSelectItem Value="SortOrder.TitleAscending">Title A-Z</MudSelectItem>
                            <MudSelectItem Value="SortOrder.TitleDescending">Title Z-A</MudSelectItem>
                        </MudSelect>
                        <MudTooltip Text="Show only titles already on Plex">
                            <MudToggleIconButton Toggled="_onlyAvailable" ToggledChanged="OnAvailabilityToggled"
                                                 Icon="@Icons.Material.Outlined.PlayCircle" ToggledIcon="@Icons.Material.Filled.PlayCircle" Color="Color.Primary" />
                        </MudTooltip>
                    }
                </div>
            </div>
        </MudContainer>
    </div>

    <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="browse-content">
        @if (GridMode)
        {
            @if (_loading)
            {
                <PlexRequestsHosted.Components.Shared.PosterGridSkeleton Count="18" />
            }
            else if (_view.Count == 0)
            {
                <div class="browse-empty">
                    <MudIcon Icon="@Icons.Material.Filled.MovieFilter" Style="font-size: 4rem;" />
                    <MudText Typo="Typo.h5">Nothing here</MudText>
                    <MudText Typo="Typo.body1" Class="text-secondary">Try a different genre or filter.</MudText>
                </div>
            }
            else
            {
                <div class="browse-grid">
                    @foreach (var item in _view)
                    {
                        <MediaCard Media="item" OnRequest="Request" OnPlay="Play" />
                    }
                </div>
                @if (_hasMore && !_onlyAvailable)
                {
                    <div class="browse-more">
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Large" OnClick="LoadMore" Disabled="_loadingMore">
                            @if (_loadingMore)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /><span>Loading…</span>
                            }
                            else { <span>Load More</span> }
                        </MudButton>
                    </div>
                }
            }
        }
        else
        {
            @if (_rowsLoading)
            {
                <PlexRequestsHosted.Components.Shared.PosterGridSkeleton Count="18" />
            }
            else
            {
                @foreach (var row in _rows)
                {
                    <MediaRow Title="@row.Title" Items="row.Items" SeeAllHref="@row.Href" OnRequest="Request" OnPlay="Play" />
                }
            }
        }
    </MudContainer>
</div>

@code {
    [Parameter] public string? Type { get; set; }
    [SupplyParameterFromQuery] public string? Genre { get; set; }

    private MediaType _type = MediaType.Movie;
    private string _genre = "";
    private SortOrder _sort = SortOrder.PopularityDescending;
    private bool _onlyAvailable = false;

    // Discovery (default) view
    private MediaCardDto? _featured;
    private readonly List<Row> _rows = new();
    private bool _rowsLoading = true;

    // Focused grid (genre) view
    private readonly List<MediaCardDto> _all = new();
    private List<MediaCardDto> _view = new();
    private int _page = 1;
    private bool _loading = true;
    private bool _loadingMore = false;
    private bool _hasMore = true;
    private const int PageSize = 40;
    // Number of titles fetched per discovery row (trending/popular/top/genre carousels).
    private const int RowSize = 100;

    private bool GridMode => !string.IsNullOrEmpty(_genre);

    private sealed record Row(string Title, string? Href, IReadOnlyList<MediaCardDto> Items);

    private static readonly string[] _movieGenres = { "Action", "Adventure", "Animation", "Comedy", "Crime", "Documentary", "Drama", "Family", "Fantasy", "History", "Horror", "Mystery", "Romance", "Science Fiction", "Thriller", "War", "Western" };
    private static readonly string[] _tvGenres = { "Action & Adventure", "Animation", "Comedy", "Crime", "Documentary", "Drama", "Family", "Kids", "Mystery", "Reality", "Sci-Fi & Fantasy", "War & Politics", "Western" };
    private string[] _genres => _type == MediaType.TvShow ? _tvGenres : _movieGenres;

    // Curated genre rows shown on the default discovery view (kept short to bound TMDB calls).
    private static readonly string[] _movieRowGenres = { "Action", "Comedy", "Drama", "Science Fiction", "Horror", "Animation", "Thriller" };
    private static readonly string[] _tvRowGenres = { "Action & Adventure", "Comedy", "Drama", "Sci-Fi & Fantasy", "Animation", "Crime" };

    private bool _rendered = false;
    private MediaType? _loadedType;
    private string? _loadedGenre;

    protected override async Task OnParametersSetAsync()
    {
        _type = (Type?.ToLower()) switch
        {
            "tvshow" or "tv" or "tvshows" => MediaType.TvShow,
            _ => MediaType.Movie
        };
        // Always mirror the query param. Previously this was sticky (kept the old value when
        // Genre was absent), so switching Movies -> TV Shows carried a movie-only genre into the
        // TV grid and landed on an empty state.
        _genre = Genre ?? string.Empty;

        if (_rendered && (_type != _loadedType || _genre != _loadedGenre))
            await ReloadAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        _rendered = true;
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _loadedType = _type;
        _loadedGenre = _genre;
        if (GridMode) await LoadGridAsync();
        else await LoadRowsAsync();
    }

    // ---- Discovery rows ----
    private async Task LoadRowsAsync()
    {
        _rowsLoading = true;
        _rows.Clear();
        _featured = null;
        await InvokeAsync(StateHasChanged);
        try
        {
            var typeLabel = _type == MediaType.TvShow ? "tvshow" : "movie";
            var trendingTask = PlexApiService.GetTrendingAsync(_type, 1, RowSize);
            var popularTask = PlexApiService.GetPopularAsync(_type, 1, RowSize);
            var topTask = PlexApiService.GetTopRatedAsync(_type, 1, RowSize);
            var rowGenres = _type == MediaType.TvShow ? _tvRowGenres : _movieRowGenres;
            var genreTasks = rowGenres.Select(g => PlexApiService.GetByGenreAsync(_type, g, 1, RowSize)).ToList();

            await Task.WhenAll(new[] { trendingTask, popularTask, topTask }.Concat(genreTasks));

            var trending = trendingTask.Result;
            _featured = trending.FirstOrDefault();

            var built = new List<Row>
            {
                new($"Trending {(_type == MediaType.TvShow ? "Shows" : "Movies")}", null, trending.Skip(1).ToList()),
                new("Popular", null, popularTask.Result),
                new("Top Rated", null, topTask.Result),
            };
            for (int i = 0; i < rowGenres.Length; i++)
                built.Add(new Row(rowGenres[i], $"/browse/{typeLabel}?genre={Uri.EscapeDataString(rowGenres[i])}", genreTasks[i].Result));

            // Overlay availability + my status across everything on the page.
            var all = new List<MediaCardDto>();
            if (_featured is not null) all.Add(_featured);
            foreach (var r in built) all.AddRange(r.Items);
            await AnnotateAsync(all);

            _rows.AddRange(built.Where(r => r.Items.Count > 0));
        }
        catch { /* rows are best-effort */ }
        finally
        {
            _rowsLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    // ---- Focused grid (a chosen genre) ----
    private async Task LoadGridAsync()
    {
        _loading = true;
        _all.Clear();
        _page = 1;
        _hasMore = true;
        await InvokeAsync(StateHasChanged);
        await FetchAsync();
        _loading = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadMore()
    {
        if (_loadingMore || !_hasMore) return;
        _loadingMore = true;
        _page++;
        await FetchAsync();
        _loadingMore = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task FetchAsync()
    {
        try
        {
            var page = await PlexApiService.GetByGenreAsync(_type, _genre, _page, PageSize);
            _hasMore = page.Count >= PageSize;
            if (page.Count > 0) { await AnnotateAsync(page); _all.AddRange(page); }
            ApplyView();
        }
        catch { await ToastService.ShowErrorAsync("Failed to load content."); }
    }

    private void ApplyView()
    {
        IEnumerable<MediaCardDto> q = _all;
        if (_onlyAvailable) q = q.Where(m => m.IsAvailable);
        q = _sort switch
        {
            SortOrder.TitleAscending => q.OrderBy(m => m.Title),
            SortOrder.TitleDescending => q.OrderByDescending(m => m.Title),
            SortOrder.RatingDescending => q.OrderByDescending(m => m.Rating ?? 0),
            _ => q
        };
        _view = q.ToList();
    }

    private async Task AnnotateAsync(List<MediaCardDto> items)
    {
        try
        {
            await PlexApiService.AnnotateAvailabilityAsync(items);
            var keys = items.Select(m => (m.Id, m.MediaType)).ToList();
            var statuses = await MediaRequestService.GetMyRequestStatusesAsync(keys);
            foreach (var m in items)
                if (statuses.TryGetValue($"{m.MediaType}:{m.Id}", out var st)) m.RequestStatus = st;
        }
        catch { /* best-effort */ }
    }

    private void OnTypeChanged(MediaType t)
    {
        if (t == _type) return;
        Navigation.NavigateTo($"/browse/{(t == MediaType.TvShow ? "tvshow" : "movie")}");
    }

    private void OnGenreChanged(string g)
    {
        // Navigate so the URL reflects the genre (shareable / survives refresh); the resulting
        // OnParametersSetAsync triggers the reload.
        var typeLabel = _type == MediaType.TvShow ? "tvshow" : "movie";
        Navigation.NavigateTo(string.IsNullOrWhiteSpace(g)
            ? $"/browse/{typeLabel}"
            : $"/browse/{typeLabel}?genre={Uri.EscapeDataString(g)}");
    }

    private async Task OnSortChanged(SortOrder s)
    {
        _sort = s;
        if (s is SortOrder.TitleAscending or SortOrder.TitleDescending or SortOrder.RatingDescending)
        { ApplyView(); await InvokeAsync(StateHasChanged); }
        else await LoadGridAsync();
    }

    private async Task OnAvailabilityToggled(bool value)
    {
        _onlyAvailable = value;
        ApplyView();
        await InvokeAsync(StateHasChanged);
    }

    private async Task Request(MediaCardDto media)
    {
        var result = await MediaRequestService.RequestMediaAsync(media.Id, media.MediaType);
        if (result.Success)
        {
            media.RequestStatus = RequestStatus.Pending;
            await ToastService.ShowSuccessAsync($"{media.Title} has been requested!");
            await InvokeAsync(StateHasChanged);
        }
        else await ToastService.ShowErrorAsync(result.ErrorMessage ?? "Failed to request");
    }

    private void Play(MediaCardDto media)
    {
        if (!string.IsNullOrEmpty(media.PlexUrl)) Navigation.NavigateTo(media.PlexUrl, true);
    }

    private void Details(MediaCardDto media)
        => Navigation.NavigateTo($"/media/{media.MediaType.ToString().ToLower()}/{media.Id}");

    private string GetPageTitle()
    {
        var baseTitle = _type == MediaType.TvShow ? "TV Shows" : "Movies";
        return string.IsNullOrEmpty(_genre) ? baseTitle : $"{_genre} {baseTitle}";
    }

    private static string Truncate(string s, int max) => s.Length <= max ? s : s.Substring(0, max) + "…";

    private static string SortLabel(SortOrder s) => s switch
    {
        SortOrder.PopularityDescending => "Most Popular",
        SortOrder.RatingDescending => "Highest Rated",
        SortOrder.DateDescending => "Newest",
        SortOrder.TitleAscending => "Title A-Z",
        SortOrder.TitleDescending => "Title Z-A",
        _ => s.ToString()
    };
}
