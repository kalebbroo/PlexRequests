@page "/admin"
@attribute [Authorize(Roles = "Admin")]
@inject NavigationManager Nav

<PageTitle>Admin - Plex Requests</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-6">
    <MudTabs ActivePanelIndex="_activeIndex" ActivePanelIndexChanged="OnTabChanged" Elevation="0" Rounded="false" Color="Color.Primary" SliderColor="Color.Primary" Class="custom-tabs">
        <MudTabPanel Text="Server Health">
            <div class="pt-4"><AdminServerHealthPanel /></div>
        </MudTabPanel>
        <MudTabPanel Text="Approvals">
            <div class="pt-4"><AdminApprovalsPanel /></div>
        </MudTabPanel>
        <MudTabPanel Text="Issues">
            <div class="pt-4"><AdminIssuesPanel /></div>
        </MudTabPanel>
        <MudTabPanel Text="Quality">
            <div class="pt-4"><AdminQualityPanel /></div>
        </MudTabPanel>
        <MudTabPanel Text="Downloads">
            <div class="pt-4"><AdminDownloadsPanel /></div>
        </MudTabPanel>
        <MudTabPanel Text="Library Organization">
            <div class="pt-4"><AdminLibraryOrganizationPanel /></div>
        </MudTabPanel>
        <MudTabPanel Text="Network Drives">
            <div class="pt-4"><AdminNetworkSharesPanel /></div>
        </MudTabPanel>
        <MudTabPanel Text="Users &amp; Roles">
            <div class="pt-4"><AdminUsersPanel /></div>
        </MudTabPanel>
        <MudTabPanel Text="Jobs">
            <div class="pt-4"><AdminJobsPanel /></div>
        </MudTabPanel>
    </MudTabs>
</MudContainer>

@code {
    // Must match the MudTabPanel order above — used for ?tab= deep links.
    private static readonly string[] TabKeys = { "health", "approvals", "issues", "quality", "downloads", "library", "network", "users", "jobs" };
    private int _activeIndex;

    [SupplyParameterFromQuery(Name = "tab")]
    public string? Tab { get; set; }

    protected override void OnParametersSet()
    {
        var idx = Array.IndexOf(TabKeys, Tab?.ToLowerInvariant() ?? string.Empty);
        if (idx >= 0) _activeIndex = idx;
    }

    private void OnTabChanged(int index)
    {
        _activeIndex = index;
        // Keep the URL in sync so refresh/share lands on the same tab.
        Nav.NavigateTo($"/admin?tab={TabKeys[index]}", forceLoad: false, replace: true);
    }
}
