@page "/admin"
@attribute [Authorize(Roles = "Admin")]
@using Microsoft.AspNetCore.WebUtilities
@inject NavigationManager Nav

<PageTitle>Admin - Plex Requests</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-6">
    <MudTabs @bind-ActivePanelIndex="_activeIndex" Elevation="0" Rounded="false" Color="Color.Primary" SliderColor="Color.Primary" Class="custom-tabs">
        <MudTabPanel Text="Server Health">
            <div class="pt-4"><AdminServerHealthPanel /></div>
        </MudTabPanel>
        <MudTabPanel Text="Approvals">
            <div class="pt-4"><AdminApprovalsPanel /></div>
        </MudTabPanel>
        <MudTabPanel Text="Issues">
            <div class="pt-4"><AdminIssuesPanel /></div>
        </MudTabPanel>
        <MudTabPanel Text="Quality">
            <div class="pt-4"><AdminQualityPanel /></div>
        </MudTabPanel>
        <MudTabPanel Text="Downloads">
            <div class="pt-4"><AdminDownloadsPanel /></div>
        </MudTabPanel>
        <MudTabPanel Text="Users &amp; Roles">
            <div class="pt-4"><AdminUsersPanel /></div>
        </MudTabPanel>
    </MudTabs>
</MudContainer>

@code {
    private static readonly string[] TabKeys = { "health", "approvals", "issues", "quality", "downloads", "users" };
    private int _activeIndex;

    protected override void OnInitialized()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);
        if (query.TryGetValue("tab", out var tab))
        {
            var idx = Array.IndexOf(TabKeys, tab.ToString().ToLowerInvariant());
            if (idx >= 0) _activeIndex = idx;
        }
    }
}
