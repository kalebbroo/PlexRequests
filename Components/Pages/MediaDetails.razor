@page "/media/{type}/{id:int}"
@attribute [Authorize]
@inject PlexRequestsHosted.Services.Abstractions.IPlexApiService PlexApiService
@inject PlexRequestsHosted.Services.Abstractions.IMediaRequestService MediaRequestService
@inject PlexRequestsHosted.Services.Abstractions.IToastService ToastService
@inject PlexRequestsHosted.Services.Implementations.IMediaIssueService IssueService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<PageTitle>@(_media?.Title ?? "Loading...") - Plex Requests</PageTitle>

@if (_loading)
{
    <div class="loading-skeleton">
        <div class="skeleton-hero"></div>
        <div class="skeleton-content">
            <MudContainer MaxWidth="MaxWidth.Large">
                <MudSkeleton SkeletonType="SkeletonType.Text" Width="300px" Height="60px" />
                <MudSkeleton SkeletonType="SkeletonType.Text" Width="500px" Height="30px" />
                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="100%" Height="100px" />
            </MudContainer>
        </div>
    </div>
}
else if (_media == null)
{
    <MudContainer MaxWidth="MaxWidth.Medium" Class="py-8">
        <div style="text-align: center; padding: 4rem 0;">
            <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Style="font-size: 4rem;" />
            <MudText Typo="Typo.h4" Class="mt-4">Content Not Found</MudText>
            <MudText Typo="Typo.body1" Color="Color.Tertiary">
                This title isn't available right now.
            </MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/" Class="mt-4">
                Browse Home
            </MudButton>
        </div>
    </MudContainer>
}
else
{
    <div class="details-container">
        <!-- Hero Section -->
        <section class="details-hero">
            <div class="hero-background">
                @if (!string.IsNullOrEmpty(_media.BackdropUrl))
                {
                    <img src="@_media.BackdropUrl" alt="" class="backdrop-image" />
                }
                <div class="hero-gradient"></div>
            </div>
            
            <div class="hero-content">
                <MudContainer MaxWidth="MaxWidth.Large">
                    <div class="hero-grid">
                        <div class="poster-section">
                            @if (!string.IsNullOrEmpty(_media.PosterUrl))
                            {
                                <img src="@_media.PosterUrl" alt="@_media.Title" class="poster" fetchpriority="high" />
                            }
                            <div class="poster-actions mobile-only">
                                @if (_media.IsAvailable)
                                {
                                    <button class="action-btn primary full" @onclick="PlayNow">
                                        <MudIcon Icon="@Icons.Material.Filled.PlayArrow" />
                                        <span>Play</span>
                                    </button>
                                }
                                else if (_media.RequestStatus == PlexRequestsHosted.Shared.Enums.RequestStatus.None)
                                {
                                    <button class="action-btn primary full" @onclick="RequestMedia">
                                        <MudIcon Icon="@Icons.Material.Filled.Add" />
                                        <span>Request</span>
                                    </button>
                                }
                                else
                                {
                                    <button class="action-btn secondary full" disabled>
                                        <MudIcon Icon="@Icons.Material.Filled.Schedule" />
                                        <span>@GetRequestStatusText()</span>
                                    </button>
                                }
                            </div>
                        </div>
                        
                        <div class="info-section">
                            <h1 class="title">@_media.Title</h1>
                            
                            @if (!string.IsNullOrEmpty(_media.Tagline))
                            {
                                <p class="tagline">@_media.Tagline</p>
                            }
                            
                            <div class="metadata">
                                @if (_media.Rating.HasValue)
                                {
                                    <div class="meta-item rating">
                                        <MudIcon Icon="@Icons.Material.Filled.Star" />
                                        <span>@_media.Rating.Value.ToString("0.0")</span>
                                    </div>
                                }
                                @if (_media.Year.HasValue)
                                {
                                    <span class="meta-item">@_media.Year</span>
                                }
                                @if (_media.MediaType == PlexRequestsHosted.Shared.Enums.MediaType.TvShow && _media.TotalSeasons > 0)
                                {
                                    <span class="meta-item">@_media.TotalSeasons Seasons</span>
                                }
                                @if (_media.Runtime.HasValue)
                                {
                                    <span class="meta-item">@FormatRuntime(_media.Runtime.Value)</span>
                                }
                                @if (!string.IsNullOrEmpty(_media.ContentRating))
                                {
                                    <span class="meta-badge">@_media.ContentRating</span>
                                }
                                @if (!string.IsNullOrEmpty(_media.Quality))
                                {
                                    <span class="quality-badge @GetQualityClass()">@_media.Quality</span>
                                }
                            </div>
                            
                            <div class="actions desktop-only">
                                @if (_media.IsAvailable)
                                {
                                    <button class="action-btn primary large" @onclick="PlayNow">
                                        <MudIcon Icon="@Icons.Material.Filled.PlayArrow" />
                                        <span>Play</span>
                                    </button>
                                }
                                else if (_media.RequestStatus == PlexRequestsHosted.Shared.Enums.RequestStatus.None)
                                {
                                    <button class="action-btn primary large" @onclick="RequestMedia">
                                        <MudIcon Icon="@Icons.Material.Filled.Add" />
                                        <span>Request</span>
                                    </button>
                                }
                                else
                                {
                                    <button class="action-btn secondary large" disabled>
                                        <MudIcon Icon="@Icons.Material.Filled.Schedule" />
                                        <span>@GetRequestStatusText()</span>
                                    </button>
                                }
                                
                                <button class="action-btn secondary large" @onclick="ToggleWatchlist">
                                    <MudIcon Icon="@(_inWatchlist ? Icons.Material.Filled.Check : Icons.Material.Filled.Add)" />
                                    <span>@(_inWatchlist ? "In My List" : "My List")</span>
                                </button>
                                
                                @if (!string.IsNullOrEmpty(_media.TrailerUrl))
                                {
                                    <button class="action-btn secondary" @onclick="PlayTrailer">
                                        <MudIcon Icon="@Icons.Material.Filled.PlayCircleOutline" />
                                        <span>Trailer</span>
                                    </button>
                                }

                                @if (_media.IsAvailable)
                                {
                                    <button class="action-btn secondary" @onclick="() => _reportOpen = true">
                                        <MudIcon Icon="@Icons.Material.Filled.ReportProblem" />
                                        <span>Report a Problem</span>
                                    </button>
                                }
                            </div>
                            
                            @if (!string.IsNullOrEmpty(_media.Overview))
                            {
                                <div class="overview">
                                    <p>@_media.Overview</p>
                                </div>
                            }
                            
                            @if (_media.Genres?.Any() == true)
                            {
                                <div class="genres">
                                    <span class="label">Genres:</span>
                                    @foreach (String genre in _media.Genres)
                                    {
                                        <a href="/browse?genre=@genre" class="genre-link">@genre</a>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </MudContainer>
            </div>
        </section>

        <!-- Details Tabs -->
        <section class="details-tabs">
            <MudContainer MaxWidth="MaxWidth.Large">
                <MudTabs Elevation="0" Rounded="false" Centered="false" Color="Color.Default" SliderColor="Color.Primary" Class="custom-tabs">
                    @if (_media.MediaType == PlexRequestsHosted.Shared.Enums.MediaType.TvShow)
                    {
                        <MudTabPanel Text="Seasons">
                            <div class="episodes-section">
                                @if (_media.Seasons?.Any() == true)
                                {
                                    <MudText Typo="Typo.body2" Class="mb-3">Expand a season to pick individual episodes, tick whole seasons, or request the entire series. Titles already on Plex are greyed out.</MudText>
                                    <div class="seasons-list">
                                        @foreach (var season in _media.Seasons.Where(s => s.SeasonNumber > 0).OrderBy(s => s.SeasonNumber))
                                        {
                                            var seasonAvailable = _availableSeasons.Contains(season.SeasonNumber);
                                            <div class="season-block @(seasonAvailable ? "is-available" : "")">
                                                <div class="season-row">
                                                    <MudCheckBox T="bool" Value="@_selectedSeasons.Contains(season.SeasonNumber)"
                                                                 ValueChanged="@((bool v) => ToggleSeason(season.SeasonNumber, v))"
                                                                 Disabled="@seasonAvailable" Dense="true" />
                                                    <div class="season-meta" @onclick="() => ToggleExpand(season.SeasonNumber)">
                                                        <MudText Typo="Typo.subtitle1">Season @season.SeasonNumber</MudText>
                                                        <MudText Typo="Typo.caption" Color="Color.Tertiary">@season.EpisodeCount episodes</MudText>
                                                    </div>
                                                    @if (seasonAvailable)
                                                    {
                                                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text">On Plex</MudChip>
                                                    }
                                                    <MudIconButton Icon="@(_expanded.Contains(season.SeasonNumber) ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                                                                   Size="Size.Small" OnClick="() => ToggleExpand(season.SeasonNumber)" />
                                                </div>

                                                @if (_expanded.Contains(season.SeasonNumber))
                                                {
                                                    <div class="episode-list">
                                                        @if (!_episodes.ContainsKey(season.SeasonNumber))
                                                        {
                                                            <div class="episode-loading"><MudProgressCircular Indeterminate="true" Size="Size.Small" /> <span>Loading episodes…</span></div>
                                                        }
                                                        else
                                                        {
                                                            @foreach (var ep in _episodes[season.SeasonNumber])
                                                            {
                                                                <div class="episode-row @(ep.IsAvailable ? "is-available" : "")">
                                                                    <MudCheckBox T="bool" Value="@_selectedEpisodes.Contains((ep.SeasonNumber, ep.EpisodeNumber))"
                                                                                 ValueChanged="@((bool v) => ToggleEpisode(ep.SeasonNumber, ep.EpisodeNumber, v))"
                                                                                 Disabled="@(ep.IsAvailable || !ep.HasAired)" Dense="true" />
                                                                    <span class="episode-num">E@ep.EpisodeNumber</span>
                                                                    <span class="episode-name">@ep.Name</span>
                                                                    @if (ep.IsAvailable)
                                                                    {
                                                                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text">On Plex</MudChip>
                                                                    }
                                                                    else if (!ep.HasAired)
                                                                    {
                                                                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Text">@(ep.AirDate?.ToString("MMM d, yyyy") ?? "Unaired")</MudChip>
                                                                    }
                                                                </div>
                                                            }
                                                        }
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </div>

                                    <div class="season-actions">
                                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="RequestSelectedEpisodes" Disabled="@(_selectedEpisodes.Count == 0)">
                                            Request @_selectedEpisodes.Count Episode@(_selectedEpisodes.Count == 1 ? "" : "s")
                                        </MudButton>
                                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="RequestSelectedSeasons" Disabled="@(_selectedSeasons.Count == 0)">
                                            Request @_selectedSeasons.Count Season@(_selectedSeasons.Count == 1 ? "" : "s")
                                        </MudButton>
                                        @if (!SeriesFullyOnPlex)
                                        {
                                            <MudTooltip Text="New episodes may be auto-downloaded as they air, depending on server settings">
                                                <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="RequestEntireSeries">Request Entire Series</MudButton>
                                            </MudTooltip>
                                        }
                                        else
                                        {
                                            <MudChip T="string" Color="Color.Success" Variant="Variant.Text" Icon="@Icons.Material.Filled.CheckCircle">All aired seasons on Plex</MudChip>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <MudText Typo="Typo.body1">Season information not available</MudText>
                                }
                            </div>
                        </MudTabPanel>
                    }
                    
                    <MudTabPanel Text="More Details">
                        <div class="more-details-grid">
                            @if (_media.Cast?.Any() == true)
                            {
                                <div class="detail-group">
                                    <h3>Cast</h3>
                                    <p>@string.Join(", ", _media.Cast.Take(10))</p>
                                </div>
                            }
                            @if (_media.Directors?.Any() == true)
                            {
                                <div class="detail-group">
                                    <h3>Directors</h3>
                                    <p>@string.Join(", ", _media.Directors)</p>
                                </div>
                            }
                            @if (_media.Writers?.Any() == true)
                            {
                                <div class="detail-group">
                                    <h3>Writers</h3>
                                    <p>@string.Join(", ", _media.Writers)</p>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(_media.Studio) || !string.IsNullOrEmpty(_media.Network))
                            {
                                <div class="detail-group">
                                    <h3>Studio</h3>
                                    <p>@(_media.Studio ?? _media.Network)</p>
                                </div>
                            }
                            @if (_media.ReleaseDate.HasValue || _media.FirstAired.HasValue)
                            {
                                <div class="detail-group">
                                    <h3>Release Date</h3>
                                    <p>@((_media.ReleaseDate ?? _media.FirstAired)?.ToString("MMMM d, yyyy"))</p>
                                </div>
                            }
                            @if (_media.Languages?.Any() == true)
                            {
                                <div class="detail-group">
                                    <h3>Languages</h3>
                                    <p>@string.Join(", ", _media.Languages)</p>
                                </div>
                            }
                        </div>
                    </MudTabPanel>
                    
                    <MudTabPanel Text="Similar">
                        <div class="similar-section">
                            @if (_similarMedia?.Any() == true)
                            {
                                <div class="similar-grid">
                                    @foreach (PlexRequestsHosted.Shared.DTOs.MediaCardDto similar in _similarMedia)
                                    {
                                        <PlexRequestsHosted.Components.Shared.MediaCard Media="similar" OnRequest="RequestSimilar" />
                                    }
                                </div>
                            }
                            else
                            {
                                <MudText Typo="Typo.body1">No similar titles available</MudText>
                            }
                        </div>
                    </MudTabPanel>
                </MudTabs>
            </MudContainer>
        </section>
    </div>
}

<MudDialog @bind-Visible="_reportOpen" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true }">
    <TitleContent><MudText Typo="Typo.h6"><MudIcon Icon="@Icons.Material.Filled.ReportProblem" Class="mr-2" />Report a Problem</MudText></TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body2" Class="mb-3">Something wrong with "@(_media?.Title)" on Plex? Tell us and an admin can re-download or fix it.</MudText>
        <MudSelect T="string" @bind-Value="_reportReason" Label="What's wrong?" Variant="Variant.Outlined" Dense="true" Class="mb-3">
            <MudSelectItem Value="@("Bad quality")">Bad quality / low resolution</MudSelectItem>
            <MudSelectItem Value="@("Playback broken")">Won't play / playback error</MudSelectItem>
            <MudSelectItem Value="@("Wrong version")">Wrong version / cut / language</MudSelectItem>
            <MudSelectItem Value="@("Missing subtitles")">Missing or bad subtitles</MudSelectItem>
            <MudSelectItem Value="@("Corrupt / incomplete")">Corrupt or incomplete file</MudSelectItem>
            <MudSelectItem Value="@("Other")">Other</MudSelectItem>
        </MudSelect>
        <MudTextField @bind-Value="_reportDetail" Label="Details (optional)" Variant="Variant.Outlined" Lines="3" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _reportOpen = false">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SubmitReport" Disabled="_reportSubmitting">Submit report</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public String? Type { get; set; }
    [Parameter] public Int32 Id { get; set; }

    private PlexRequestsHosted.Shared.DTOs.MediaDetailDto? _media;
    private List<PlexRequestsHosted.Shared.DTOs.MediaCardDto>? _similarMedia;
    private PlexRequestsHosted.Shared.DTOs.SeasonDto? _selectedSeason;
    private Boolean _loading = true;
    private Boolean _inWatchlist = false;

    private bool _rendered = false;
    private int _loadedId = -1;
    private string? _loadedType;

    // Load after first render (shell/skeleton paints instantly), and again when the route id/type
    // changes on the same component instance (e.g. clicking a "Similar" title).
    protected override async Task OnParametersSetAsync()
    {
        if (_rendered && (Id != _loadedId || Type != _loadedType))
            await LoadAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        _rendered = true;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loadedId = Id;
        _loadedType = Type;
        _loading = true;
        _media = null;
        _similarMedia = null;
        _availableSeasons = new();
        _selectedSeasons.Clear();
        _selectedEpisodes.Clear();
        _expanded.Clear();
        _episodes.Clear();
        await InvokeAsync(StateHasChanged);

        try
        {
            var mediaType = ParseType(Type);
            _media = await PlexApiService.GetMediaDetailsAsync(Id, mediaType);
            if (_media is null) return;

            // Phase 1: show the title/poster/overview immediately.
            if (_media.Seasons?.Any() == true) _selectedSeason = _media.Seasons.First();
            _loading = false;
            await InvokeAsync(StateHasChanged);

            // Phase 2: enrich (badges, watchlist, seasons, recommendations). The recommendations fetch
            // is a TMDB call (own HttpClient) so it can overlap the DB work; the DB calls themselves
            // run sequentially because scoped services share the circuit's single AppDbContext.
            var similarTask = PlexApiService.GetSimilarAsync(_media.Id, mediaType, 12);

            await PlexApiService.AnnotateAvailabilityAsync(new List<PlexRequestsHosted.Shared.DTOs.MediaCardDto> { _media });
            var statuses = await MediaRequestService.GetMyRequestStatusesAsync(new List<(int, PlexRequestsHosted.Shared.Enums.MediaType)> { (_media.Id, _media.MediaType) });
            if (statuses.TryGetValue($"{_media.MediaType}:{_media.Id}", out var st)) _media.RequestStatus = st;
            _inWatchlist = await MediaRequestService.IsInWatchlistAsync(_media.Id, _media.MediaType);
            if (_media.MediaType == PlexRequestsHosted.Shared.Enums.MediaType.TvShow)
                _availableSeasons = (await PlexApiService.GetAvailableSeasonsAsync(_media.Id)).ToHashSet();
            await InvokeAsync(StateHasChanged);

            _similarMedia = (await similarTask)?.Where(m => m.Id != _media.Id).Take(12).ToList();
            if (_similarMedia?.Any() == true)
            {
                await PlexApiService.AnnotateAvailabilityAsync(_similarMedia);
                var map = await MediaRequestService.GetMyRequestStatusesAsync(_similarMedia.Select(m => (m.Id, m.MediaType)).ToList());
                foreach (var m in _similarMedia)
                    if (map.TryGetValue($"{m.MediaType}:{m.Id}", out var st2)) m.RequestStatus = st2;
                await InvokeAsync(StateHasChanged);
            }
        }
        finally
        {
            _loading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private PlexRequestsHosted.Shared.Enums.MediaType ParseType(String? t)
        => string.Equals(t, "tvshow", StringComparison.OrdinalIgnoreCase) ? PlexRequestsHosted.Shared.Enums.MediaType.TvShow
         : string.Equals(t, "movie", StringComparison.OrdinalIgnoreCase) ? PlexRequestsHosted.Shared.Enums.MediaType.Movie
         : PlexRequestsHosted.Shared.Enums.MediaType.Movie;

    private async Task RequestMedia()
    {
        if (_media == null) return;
        
        PlexRequestsHosted.Shared.DTOs.MediaRequestResult result = await MediaRequestService.RequestMediaAsync(_media.Id, _media.MediaType);
        if (result.Success)
        {
            _media.RequestStatus = PlexRequestsHosted.Shared.Enums.RequestStatus.Pending;
            await ToastService.ShowSuccessAsync($"{_media.Title} has been requested!");
            StateHasChanged();
        }
        else
        {
            await ToastService.ShowErrorAsync(result.ErrorMessage ?? "Failed to request");
        }
    }

    private readonly HashSet<int> _selectedSeasons = new();
    private readonly HashSet<(int season, int episode)> _selectedEpisodes = new();
    private readonly HashSet<int> _expanded = new();
    private readonly Dictionary<int, List<PlexRequestsHosted.Shared.DTOs.EpisodeDto>> _episodes = new();
    private HashSet<int> _availableSeasons = new();

    // Report-a-Problem dialog
    private bool _reportOpen;
    private bool _reportSubmitting;
    private string _reportReason = "Bad quality";
    private string _reportDetail = string.Empty;

    private async Task SubmitReport()
    {
        if (_media is null) return;
        _reportSubmitting = true;
        try
        {
            var ok = await IssueService.ReportIssueAsync(_media.Id, _media.MediaType, _media.Title, _media.PosterUrl, _reportReason, _reportDetail);
            if (ok)
            {
                await ToastService.ShowSuccessAsync("Thanks — your report was sent to the admins.");
                _reportOpen = false;
                _reportDetail = string.Empty;
            }
            else await ToastService.ShowErrorAsync("Couldn't submit the report.");
        }
        finally { _reportSubmitting = false; }
    }

    // True when every aired season of the show is already on Plex — so "Request Entire Series" would be
    // redundant. Unaired future seasons are ignored (the monitor handles those).
    private bool SeriesFullyOnPlex
    {
        get
        {
            var aired = _media?.Seasons?
                .Where(s => s.SeasonNumber > 0 && (!s.AirDate.HasValue || s.AirDate.Value.Date <= DateTime.UtcNow.Date))
                .ToList();
            return aired is { Count: > 0 } && aired.All(s => _availableSeasons.Contains(s.SeasonNumber));
        }
    }

    private async Task ToggleExpand(int season)
    {
        if (!_expanded.Add(season)) { _expanded.Remove(season); return; }
        if (_media is not null && !_episodes.ContainsKey(season))
        {
            var eps = await PlexApiService.GetSeasonEpisodesAsync(_media.Id, season);
            _episodes[season] = eps;
            StateHasChanged();
        }
    }

    private void ToggleSeason(int seasonNumber, bool selected)
    {
        if (selected) _selectedSeasons.Add(seasonNumber); else _selectedSeasons.Remove(seasonNumber);
    }

    private void ToggleEpisode(int season, int episode, bool selected)
    {
        if (selected) _selectedEpisodes.Add((season, episode)); else _selectedEpisodes.Remove((season, episode));
    }

    private async Task RequestSelectedSeasons()
    {
        if (_media is null || _selectedSeasons.Count == 0) return;
        var result = await MediaRequestService.RequestSeasonsAsync(_media.Id, _media.MediaType, _selectedSeasons.ToList());
        await AfterTvRequest(result, $"Requested {_selectedSeasons.Count} season(s) of {_media.Title}!");
        if (result.Success) _selectedSeasons.Clear();
    }

    private async Task RequestSelectedEpisodes()
    {
        if (_media is null || _selectedEpisodes.Count == 0) return;
        var result = await MediaRequestService.RequestEpisodesAsync(_media.Id, _media.MediaType, _selectedEpisodes.ToList());
        await AfterTvRequest(result, $"Requested {_selectedEpisodes.Count} episode(s) of {_media.Title}!");
        if (result.Success) _selectedEpisodes.Clear();
    }

    private async Task RequestEntireSeries()
    {
        if (_media is null) return;
        var result = await MediaRequestService.RequestSeriesAsync(_media.Id, _media.MediaType);
        await AfterTvRequest(result, $"{_media.Title} (entire series) has been requested!");
    }

    private async Task AfterTvRequest(PlexRequestsHosted.Shared.DTOs.MediaRequestResult result, string successMessage)
    {
        if (result.Success)
        {
            if (_media is not null) _media.RequestStatus = PlexRequestsHosted.Shared.Enums.RequestStatus.Pending;
            await ToastService.ShowSuccessAsync(successMessage);
            StateHasChanged();
        }
        else await ToastService.ShowErrorAsync(result.ErrorMessage ?? "Failed to request");
    }

    private async Task RequestSimilar(PlexRequestsHosted.Shared.DTOs.MediaCardDto media)
    {
        var result = await MediaRequestService.RequestMediaAsync(media.Id, media.MediaType);
        if (result.Success)
        {
            media.RequestStatus = PlexRequestsHosted.Shared.Enums.RequestStatus.Pending;
            await ToastService.ShowSuccessAsync($"{media.Title} has been requested!");
            StateHasChanged();
        }
        else await ToastService.ShowErrorAsync(result.ErrorMessage ?? "Failed to request");
    }

    private void PlayNow()
    {
        if (!string.IsNullOrEmpty(_media?.PlexUrl))
            Navigation.NavigateTo(_media.PlexUrl, true);
    }

    private void PlayTrailer()
    {
        if (!string.IsNullOrEmpty(_media?.TrailerUrl))
            Navigation.NavigateTo(_media.TrailerUrl, true);
    }

    private async Task ToggleWatchlist()
    {
        if (_media == null) return;
        
        Boolean success = _inWatchlist
            ? await MediaRequestService.RemoveFromWatchlistAsync(_media.Id, _media.MediaType)
            : await MediaRequestService.AddToWatchlistAsync(_media.Id, _media.MediaType);
            
        if (success)
        {
            _inWatchlist = !_inWatchlist;
            String message = _inWatchlist ? "Added to My List" : "Removed from My List";
            await ToastService.ShowInfoAsync(message);
        }
    }

    private void NavigateToMedia(PlexRequestsHosted.Shared.DTOs.MediaCardDto media)
    {
        Navigation.NavigateTo($"/media/{media.MediaType.ToString().ToLower()}/{media.Id}");
    }

    private String GetRequestStatusText() => _media?.RequestStatus switch
    {
        PlexRequestsHosted.Shared.Enums.RequestStatus.Pending => "Pending",
        PlexRequestsHosted.Shared.Enums.RequestStatus.Approved => "Approved",
        _ => "Requested"
    };

    private String GetQualityClass() => _media?.Quality?.ToUpper() switch
    {
        "4K" or "UHD" => "quality-4k",
        "1080P" or "FHD" => "quality-hd",
        _ => ""
    };

    private String FormatRuntime(Int32 minutes)
    {
        if (minutes < 60) return $"{minutes}m";
        Int32 hours = minutes / 60;
        Int32 mins = minutes % 60;
        return mins > 0 ? $"{hours}h {mins}m" : $"{hours}h";
    }
}
