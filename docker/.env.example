# Copy to ./.env (repo root) and fill in. docker-compose reads it automatically.

# --- Web app ---
FULFILLMENT_API_KEY=change-me-to-a-long-random-secret   # shared with the downloader
TMDB_API_KEY=your-tmdb-api-key
ADMIN_USERNAMES=your-plex-username                        # comma-separated
PLEX_URL=http://your-plex-host:32400
PLEX_TOKEN=your-plex-token

# --- Deluge ---
DELUGE_PASSWORD=deluge

# --- VPN (gluetun; example uses WireGuard) ---
VPN_PROVIDER=mullvad
WIREGUARD_PRIVATE_KEY=your-wireguard-private-key
WIREGUARD_ADDRESSES=10.0.0.2/32
VPN_COUNTRIES=Netherlands
# Docker network subnet so the downloader can reach `web` without the VPN.
DOCKER_SUBNET=172.16.0.0/12

# --- Misc ---
TZ=Etc/UTC
