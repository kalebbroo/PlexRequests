# Copy to ./.env (repo root) and fill in. docker-compose reads it automatically.
# Which vars you need depends on your setup (see docker-compose.yml header for the 3 scenarios).

# --- Web app (always needed) ---
FULFILLMENT_API_KEY=change-me-to-a-long-random-secret   # shared with the downloader
TMDB_API_KEY=your-tmdb-api-key
ADMIN_USERNAMES=your-plex-username                        # comma-separated
PLEX_URL=http://your-plex-host:32400
PLEX_TOKEN=your-plex-token
TZ=Etc/UTC

# --- Discord bridge (optional; only if using the PlexBot extension) ---
BRIDGE_ENABLED=false
BRIDGE_API_KEY=

# --- Torrent client ---
# Bring your own: point this at your existing Deluge (leave unset to use the --profile torrent one).
# - Deluge on a different host: DELUGE_URL=http://that-host:8112
# - Deluge installed on THIS SAME host, outside Docker: DELUGE_URL=http://host.docker.internal:8112
#   (the downloader service already maps host.docker.internal via extra_hosts in docker-compose.yml)
#DELUGE_URL=http://your-deluge-host:8112
DELUGE_PASSWORD=deluge

# --- VPN toggle (base stack) ---
# Only meaningful when the downloader runs inside a VPN namespace (the vpn stack sets this itself).
# Leave false for the base docker-compose.yml; you bring your own VPN or none.
VPN_ENABLED=false

# --- Managed VPN (only for docker-compose.vpn.yml; gluetun / WireGuard example) ---
VPN_PROVIDER=mullvad
WIREGUARD_PRIVATE_KEY=your-wireguard-private-key
WIREGUARD_ADDRESSES=10.0.0.2/32
VPN_COUNTRIES=Netherlands
# Docker network subnet so the downloader can reach `web` without the VPN.
DOCKER_SUBNET=172.16.0.0/12
